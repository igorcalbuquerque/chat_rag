# ============================================================================
# Provider selection
# ============================================================================
# LLM_PROVIDER:        openai | anthropic | gemini | ollama
# EMBEDDING_PROVIDER:  openai | gemini | sentence-transformers
#
# Default below targets OpenAI and works with the lightweight default image.
# For the 100% local, zero-cost path (Ollama LLM + MiniLM embeddings), use:
#   LLM_PROVIDER=ollama
#   EMBEDDING_PROVIDER=sentence-transformers
#   LLM_MODEL=llama3
#   EMBEDDING_MODEL=all-MiniLM-L6-v2
#   INSTALL_LOCAL_EMBEDDINGS=true   (see below — pulls torch, big image)
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# ============================================================================
# Model names
# ============================================================================
# OpenAI LLM:        gpt-4o | gpt-4o-mini | gpt-3.5-turbo
# Anthropic LLM:     claude-3-5-sonnet-latest | claude-3-5-haiku-latest
# Gemini LLM:        gemini-1.5-flash | gemini-1.5-pro
# Ollama LLM:        llama3 | mistral | gemma
LLM_MODEL=gpt-4o-mini
# OpenAI embeddings:        text-embedding-3-small | text-embedding-ada-002
# Gemini embeddings:        models/text-embedding-004
# Sentence-Transformers:    all-MiniLM-L6-v2 | all-mpnet-base-v2
EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# API keys (leave blank if using the local Ollama + MiniLM setup)
# DO NOT commit real keys.
# ============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Note: end users can also paste their own key in the frontend (sent per
# request as the X-API-Key header); it overrides the keys above when present.

# ============================================================================
# Build: install the optional local embedding stack (sentence-transformers +
# torch). Keep "false" for a small, fast image (OpenAI/Anthropic/Ollama LLM).
# Set "true" only for the fully local embeddings path.
# ============================================================================
INSTALL_LOCAL_EMBEDDINGS=false

# ============================================================================
# Build: install the OCR stack (Tesseract + PyMuPDF) to read scanned/image
# PDFs (no text layer). Keep "false" for a smaller image; set "true" if you
# need to ingest scanned documents. OCR is slow and, with paid embeddings,
# costly for large documents.
# ============================================================================
INSTALL_OCR=false
# OCR languages (Tesseract codes, '+'-separated) and render DPI.
OCR_LANGUAGE=por+eng
OCR_DPI=200

# ============================================================================
# Redis (overridden to redis://redis:6379 inside docker-compose)
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# RAG / chunking tunables
# ============================================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
HISTORY_SIZE=6
LLM_TEMPERATURE=0.0
MAX_TOKENS=1024

# Upload guardrails (DoS / cost protection).
# MAX_UPLOAD_MB is kept in sync with the Nginx client_max_body_size (300M).
MAX_UPLOAD_MB=300
MAX_FILES_PER_REQUEST=50

# ============================================================================
# Authentication (OPTIONAL — keep OFF for local use)
# ----------------------------------------------------------------------------
# When AUTH_ENABLED=false (default) the app is open and there is no login:
# just run it locally and use it. Set AUTH_ENABLED=true only for a public
# deployment — then visitors must log in with Google or GitHub and each user
# only sees their own documents and conversations. BYOK (the LLM key in the UI)
# still works the same way and is independent of login.
#
# To enable, create the OAuth apps and fill the values below:
#   Google: https://console.cloud.google.com/apis/credentials -> OAuth client
#           (type "Web"); Authorized redirect URI:
#           <BACKEND_URL>/auth/callback/google
#   GitHub: https://github.com/settings/developers -> New OAuth App;
#           Authorization callback URL: <BACKEND_URL>/auth/callback/github
# ============================================================================
AUTH_ENABLED=false
# Public URL of THIS backend (must match the OAuth redirect URIs you register).
# Local example: http://localhost:8000
BACKEND_URL=
# Where to send the browser back to after login (the frontend URL).
# Local example: http://localhost:3000
FRONTEND_URL=
# Strong random string. Signs the login token. CHANGE THIS in production:
# the app REFUSES to start with this default value when AUTH_ENABLED=true.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=dev-insecure-secret-change-me
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
