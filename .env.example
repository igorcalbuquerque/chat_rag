# ============================================================================
# Provider selection
# ============================================================================
# LLM_PROVIDER:        openai | anthropic | ollama
# EMBEDDING_PROVIDER:  openai | sentence-transformers
#
# Default below is the fully local, zero-cost setup (Ollama + MiniLM).
# To use it you need an Ollama server reachable at OLLAMA_BASE_URL with the
# chosen model pulled (e.g. `ollama pull llama3`).
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=sentence-transformers

# ============================================================================
# Model names
# ============================================================================
# OpenAI LLM:        gpt-4o | gpt-4o-mini | gpt-3.5-turbo
# Anthropic LLM:     claude-3-5-sonnet-latest | claude-3-5-haiku-latest
# Ollama LLM:        llama3 | mistral | gemma
LLM_MODEL=llama3
# OpenAI embeddings:        text-embedding-3-small | text-embedding-ada-002
# Sentence-Transformers:    all-MiniLM-L6-v2 | all-mpnet-base-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================================================
# API keys (leave blank if using the local Ollama + MiniLM setup)
# DO NOT commit real keys.
# ============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ============================================================================
# Redis (overridden to redis://redis:6379 inside docker-compose)
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# RAG / chunking tunables
# ============================================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
HISTORY_SIZE=6
LLM_TEMPERATURE=0.0
MAX_TOKENS=1024
