# ============================================================================
# Provider selection
# ============================================================================
# LLM_PROVIDER:        openai | anthropic | ollama
# EMBEDDING_PROVIDER:  openai | sentence-transformers
#
# Default below targets OpenAI and works with the lightweight default image.
# For the 100% local, zero-cost path (Ollama LLM + MiniLM embeddings), use:
#   LLM_PROVIDER=ollama
#   EMBEDDING_PROVIDER=sentence-transformers
#   LLM_MODEL=llama3
#   EMBEDDING_MODEL=all-MiniLM-L6-v2
#   INSTALL_LOCAL_EMBEDDINGS=true   (see below — pulls torch, big image)
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# ============================================================================
# Model names
# ============================================================================
# OpenAI LLM:        gpt-4o | gpt-4o-mini | gpt-3.5-turbo
# Anthropic LLM:     claude-3-5-sonnet-latest | claude-3-5-haiku-latest
# Ollama LLM:        llama3 | mistral | gemma
LLM_MODEL=gpt-4o-mini
# OpenAI embeddings:        text-embedding-3-small | text-embedding-ada-002
# Sentence-Transformers:    all-MiniLM-L6-v2 | all-mpnet-base-v2
EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# API keys (leave blank if using the local Ollama + MiniLM setup)
# DO NOT commit real keys.
# ============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ============================================================================
# Build: install the optional local embedding stack (sentence-transformers +
# torch). Keep "false" for a small, fast image (OpenAI/Anthropic/Ollama LLM).
# Set "true" only for the fully local embeddings path.
# ============================================================================
INSTALL_LOCAL_EMBEDDINGS=false

# ============================================================================
# Redis (overridden to redis://redis:6379 inside docker-compose)
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# RAG / chunking tunables
# ============================================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
HISTORY_SIZE=6
LLM_TEMPERATURE=0.0
MAX_TOKENS=1024
